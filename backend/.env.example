# Backend Environment Variables

# MySQL Database Connection (used by both Prisma CLI and runtime adapter)
DATABASE_URL="mysql://root:password@localhost:3306/sycwallet"

# JWT Secret Key
JWT_SECRET=your_jwt_secret_here

# Session Secret Key
SESSION_SECRET=your_session_secret_here

# Alchemy API Keys for different networks
RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key
RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_api_key
RPC_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key
RPC_BSC=https://bnb-mainnet.g.alchemy.com/v2/your_alchemy_api_key
RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/your_alchemy_api_key
RPC_AVALANCHE=https://avax-mainnet.g.alchemy.com/v2/your_alchemy_api_key
RPC_BASE=https://base-mainnet.g.alchemy.com/v2/your_alchemy_api_key

# SwapKit API Configuration
SWAPKIT_BASE_URL=https://api.swapkit.dev
SWAPKIT_QUOTE_PATH=/quote
SWAPKIT_SWAP_PATH=/swap

SWAPKIT_API_KEY=your_swapkit_api_key_here

# ChangeNow API Configuration
CHANGENOW_BASE_URL=https://api.changenow.io/v2
CHANGENOW_API_KEY=your_changenow_api_key_here
